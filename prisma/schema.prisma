// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductBadge {
  SALE
  JUST_IN
  BEST_SELLER
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ForumVoteDirection {
  UP
  DOWN
}

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ExchangeRate {
  id            String   @id @default(cuid())
  baseCurrency  String   @default("USD")
  quoteCurrency String   @default("VES")
  rate          Decimal  @db.Decimal(18, 6)
  source        String?
  effectiveAt   DateTime @default(now())
  fetchedAt     DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([baseCurrency, quoteCurrency, isActive])
  @@index([effectiveAt])
}

model StorefrontSetting {
  id                    String           @id @default(cuid())
  key                   String           @unique @default("default")
  locationIntro         String           @db.Text
  deliveryNote          String           @db.Text
  scheduleWeekdaysLabel String
  scheduleWeekdaysHours String
  scheduleWeekendNote   String           @db.Text
  paymentMethodsForeign String[]         @default([])
  paymentMethodsBolivar String[]         @default([])
  dispatchMethods       String[]         @default([])
  nationalCarriers      String[]         @default([])
  supportTitle          String
  supportDescription    String           @db.Text
  supportHighlight      String           @db.Text
  pickupLocations       PickupLocation[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model PickupLocation {
  id                  String            @id @default(cuid())
  storefrontSettingId String
  name                String
  description         String            @db.Text
  latitude            Decimal           @db.Decimal(9, 6)
  longitude           Decimal           @db.Decimal(9, 6)
  sortOrder           Int               @default(0)
  storefrontSetting   StorefrontSetting @relation(fields: [storefrontSettingId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([storefrontSettingId, sortOrder])
  @@index([storefrontSettingId])
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([parentId, name])
  @@index([parentId])
}

model Product {
  id                String           @id @default(cuid())
  sku               String           @unique
  slug              String           @unique
  name              String
  description       String           @db.Text
  categoryLabels    String[]         @default([])
  price             Decimal          @db.Decimal(10, 2)
  priceVes          Decimal          @default(0) @db.Decimal(14, 2)
  compareAtPrice    Decimal?         @db.Decimal(10, 2)
  compareAtPriceVes Decimal?         @db.Decimal(14, 2)
  modelNumber       String?
  primaryColor      String?
  features          String[]
  shippingInfo      String?
  stockQuantity     Int              @default(0)
  status            ProductStatus    @default(DRAFT)
  badge             ProductBadge?
  featuredRank      Int?
  averageRating     Decimal          @default(0) @db.Decimal(3, 2)
  reviewCount       Int              @default(0)
  brandId           String
  categoryId        String
  brand             Brand            @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category          Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images            ProductImage[]
  variants          ProductVariant[]
  reviews           ProductReview[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([badge])
  @@index([primaryColor])
  @@index([price])
  @@index([priceVes])
  @@index([modelNumber])
  @@index([createdAt])
  @@index([reviewCount])
  @@index([averageRating])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, sortOrder])
  @@index([productId])
  @@index([isPrimary])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  label     String
  available Boolean  @default(true)
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, label])
  @@unique([productId, sortOrder])
  @@index([productId])
}

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  reviewerName String?
  title        String?
  body         String?  @db.Text
  rating       Int
  isPublished  Boolean  @default(true)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([rating])
  @@index([isPublished])
  @@index([createdAt])
}

model User {
  id                      String                   @id @default(cuid())
  firstName               String?
  lastName                String?
  name                    String?
  email                   String                   @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?                  @db.Text
  role                    UserRole                 @default(CUSTOMER)
  accounts                Account[]
  sessions                Session[]
  forumThreads            ForumThread[]
  forumReplies            ForumReply[]
  forumThreadVotes        ForumThreadVote[]
  forumReplyVotes         ForumReplyVote[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([role])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model ForumThread {
  id        String       @id @default(cuid())
  slug      String       @unique
  title     String
  content   String       @db.Text
  tags      String[]     @default([])
  upvotes   Int          @default(0)
  downvotes Int          @default(0)
  deletedAt DateTime?
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   ForumReply[]
  votes     ForumThreadVote[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([authorId])
  @@index([createdAt])
}

model ForumReply {
  id        String     @id @default(cuid())
  threadId  String
  authorId  String
  content   String     @db.Text
  upvotes   Int        @default(0)
  downvotes Int        @default(0)
  deletedAt DateTime?
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes     ForumReplyVote[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model ForumThreadVote {
  id        String             @id @default(cuid())
  threadId  String
  userId    String
  direction ForumVoteDirection
  thread    ForumThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([threadId, userId])
  @@index([threadId])
  @@index([userId])
}

model ForumReplyVote {
  id        String             @id @default(cuid())
  replyId   String
  userId    String
  direction ForumVoteDirection
  reply     ForumReply         @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([replyId, userId])
  @@index([replyId])
  @@index([userId])
}
